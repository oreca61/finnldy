<Window x:Class="Finnldy.UI.SwipeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finnldy Swipe"
        Height="780"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        WindowState="Maximized"
        WindowStyle="None"
        Loaded="SwipeView_Loaded">


    <!-- Habe wieder nur das Design mit Ki generieren lassen promt: kannst du mir jetzt Lobby view und swipe view in einem ähnlichen design machen wie genreselectionwindow-->

    <Window.Resources>



            <Style x:Key="SwipeButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="30">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0"/>
                <GradientStop Color="#1F2937" Offset="0.45"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Button Content="✕"
            Width="42" Height="42" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#374151" Foreground="White"
            FontSize="18"
            FontWeight="Bold"
            BorderThickness="0"
            Cursor="Hand"
            Click="CloseButton_Click"/>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,22">

            <TextBlock Text="Swipe jetzt los"
                       Foreground="White"
                       FontSize="40"
                       FontWeight="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Like, Dislike oder speichere Filme für später."
                       Foreground="#9CA3AF"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>

        </StackPanel>

        <!-- Movie Card -->
        <Border Grid.Row="1"
                Width="1100"
                MaxHeight="620"
                Background="#1F2937"
                CornerRadius="28"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#374151"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="28"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Poster -->
                <Border Grid.Column="0"
                        Background="#111827"
                        CornerRadius="22"
                        ClipToBounds="True">

                    <Image x:Name="MovieCoverImage"
                           Stretch="Uniform"/>

                </Border>

                <!-- Infos -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto">

                    <StackPanel VerticalAlignment="Top">

                        <!-- Titel -->
                        <TextBlock x:Name="MovieTitleText"
                                   Foreground="White"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   Margin="0,0,0,10"/>

                        <!-- Release Date -->
                        <TextBlock x:Name="MovieReleaseDateText"
                                   Foreground="#E11D48"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"
                                   Margin="0,0,0,18"/>

                        <!-- Zusatzinfos -->
                        <WrapPanel Margin="0,0,0,20">

                            <Border Background="#111827"
                                    CornerRadius="14"
                                    Padding="14,8"
                                    Margin="0,0,10,10">

                                <TextBlock x:Name="MovieRatingText"
                                           Text="⭐ Bewertung"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Background="#111827"
                                    CornerRadius="14"
                                    Padding="14,8"
                                    Margin="0,0,10,10">

                                <TextBlock x:Name="MovieAdultText"
                                           Text="🔞 Alter"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Background="#111827"
                                    CornerRadius="14"
                                    Padding="14,8"
                                    Margin="0,0,10,10">

                                <TextBlock x:Name="MovieLanguageText"
                                           Text="🌍 Sprache"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                            </Border>

                        </WrapPanel>

                        <!-- Beschreibung -->
                        <TextBlock Text="Beschreibung"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>

                        <TextBlock x:Name="MovieDescriptionText"
                                   Foreground="#D1D5DB"
                                   FontSize="16"
                                   LineHeight="24"
                                   TextWrapping="Wrap"
                                   TextTrimming="None"/>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </Border>

        <!-- Swipe Buttons -->
        <Grid Grid.Row="2"
              Width="840"
              HorizontalAlignment="Center"
              Margin="0,28,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="WatchedButton"
                    Grid.Column="0"
                    Content="👀&#x0a;Gesehen"
                    Background="#6366F1"
                    Style="{StaticResource SwipeButton}"
                    TextBlock.TextAlignment="Center"
                    Click="WatchedButton_Click"/>

            <Button x:Name="DislikeButton"
                    Grid.Column="1"
                    Content="👎&#x0a;Dislike"
                    Background="#EF4444"
                    Style="{StaticResource SwipeButton}"
                    TextBlock.TextAlignment="Center"
                    Click="DislikeButton_Click"/>

            <Button x:Name="LikeButton"
                    Grid.Column="2"
                    Content="👍&#x0a;Like"
                    Background="#22C55E"
                    Style="{StaticResource SwipeButton}"
                    TextBlock.TextAlignment="Center"
                    Click="LikeButton_Click"/>

            <Button x:Name="WatchLaterButton"
                    Grid.Column="3"
                    Content="🕑&#x0a;Später"
                    Background="#F59E0B"
                    Style="{StaticResource SwipeButton}"
                    TextBlock.TextAlignment="Center"
                    Click="WatchLaterButton_Click"/>

        </Grid>

    </Grid>
</Window>