<Window x:Class="Finnldy.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Finnldy.UI"
        mc:Ignorable="d"
        Title="Finnldy Lobby" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text=" Finnldy Lobby"
            FontSize="32"
            FontWeight="Bold"
            HorizontalAlignment="Center"
            Margin="0,0,0,20">
        </TextBlock>
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
            <Button Content="Host a Lobby" Width="200" Height="50" Margin="0,0,0,10" Click="CreateLobbyButton_Click"/>
            <Button Content="Join a Lobby" Width="200" Height="50" Margin="0,0,0,10" Click="JoinLobbyButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
