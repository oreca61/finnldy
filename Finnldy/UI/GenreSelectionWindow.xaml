<Window x:Class="Finnldy.UI.GenreSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter auswählen"
        Height="700"
        Width="480"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

    <!-- Design habe ich mit Ki gemacht
        promt: "Erstelle ein modernes und ansprechendes Design für ein Genre-Auswahlfenster für mein Projekt -->
    <Window.Resources>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F9FAFB"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,7"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#E11D48"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="25">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,25">

            <TextBlock Text="Film-Filter"
                       Foreground="White"
                       FontSize="34"
                       FontWeight="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Wähle aus, welche Filme dir vorgeschlagen werden sollen."
                       Foreground="#9CA3AF"
                       FontSize="15"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>

        </StackPanel>

        <!-- Filterbereich -->
        <Border Grid.Row="1"
                Background="#1F2937"
                CornerRadius="24"
                Padding="22"
                BorderBrush="#374151"
                BorderThickness="1">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <!-- Genres -->
                    <TextBlock Text="Genres"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <CheckBox x:Name="ActionCheckBox"
                              Content="Action"
                              Tag="28"/>

                    <CheckBox x:Name="AdventureCheckBox"
                              Content="Abenteuer"
                              Tag="12"/>

                    <CheckBox x:Name="AnimationCheckBox"
                              Content="Animation"
                              Tag="16"/>

                    <CheckBox x:Name="ComedyCheckBox"
                              Content="Komödie"
                              Tag="35"/>

                    <CheckBox x:Name="CrimeCheckBox"
                              Content="Krimi"
                              Tag="80"/>

                    <CheckBox x:Name="DocumentaryCheckBox"
                              Content="Dokumentation"
                              Tag="99"/>

                    <CheckBox x:Name="DramaCheckBox"
                              Content="Drama"
                              Tag="18"/>

                    <CheckBox x:Name="FamilyCheckBox"
                              Content="Familie"
                              Tag="10751"/>

                    <CheckBox x:Name="FantasyCheckBox"
                              Content="Fantasy"
                              Tag="14"/>

                    <CheckBox x:Name="HistoryCheckBox"
                              Content="Historie"
                              Tag="36"/>

                    <CheckBox x:Name="HorrorCheckBox"
                              Content="Horror"
                              Tag="27"/>

                    <CheckBox x:Name="MusicCheckBox"
                              Content="Musik"
                              Tag="10402"/>

                    <CheckBox x:Name="MysteryCheckBox"
                              Content="Mystery"
                              Tag="9648"/>

                    <CheckBox x:Name="RomanceCheckBox"
                              Content="Romanze"
                              Tag="10749"/>

                    <CheckBox x:Name="ScienceFictionCheckBox"
                              Content="Science Fiction"
                              Tag="878"/>

                    <CheckBox x:Name="TvMovieCheckBox"
                              Content="TV-Film"
                              Tag="10770"/>

                    <CheckBox x:Name="ThrillerCheckBox"
                              Content="Thriller"
                              Tag="53"/>

                    <CheckBox x:Name="WarCheckBox"
                              Content="Kriegsfilm"
                              Tag="10752"/>

                    <CheckBox x:Name="WesternCheckBox"
                              Content="Western"
                              Tag="37"/>

                    
                    
                    
                    
                    
                    <TextBlock Text="Sprachen"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,25,0,10"/>

                    <CheckBox x:Name="GermanLanguageCheckBox"
                              Content="Deutsch"
                              Tag="de"
                              IsChecked="True"/>

                    <CheckBox x:Name="EnglishLanguageCheckBox"
                              Content="Englisch"
                              Tag="en"
                              IsChecked="True"/>

                    <CheckBox x:Name="FrenchLanguageCheckBox"
                              Content="Französisch"
                              Tag="fr"/>

                    <CheckBox x:Name="SpanishLanguageCheckBox"
                              Content="Spanisch"
                              Tag="es"/>

                    <CheckBox x:Name="ItalianLanguageCheckBox"
                              Content="Italienisch"
                              Tag="it"/>

                    <CheckBox x:Name="JapaneseLanguageCheckBox"
                              Content="Japanisch"
                              Tag="ja"/>

                    <CheckBox x:Name="KoreanLanguageCheckBox"
                              Content="Koreanisch"
                              Tag="ko"/>

                    <CheckBox x:Name="HindiLanguageCheckBox"
                              Content="Hindi"
                              Tag="hi"/>


                    
                    
                    <TextBlock Text="Altersfilter"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,25,0,10"/>

                    <CheckBox x:Name="HideAdultMoviesCheckBox"
                              Content="Erwachsenenfilme ausblenden"
                              IsChecked="True"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- Start Button -->
        <Button Grid.Row="2"
            Content="Lobby erstellen"
            Style="{StaticResource StartButton}"
            Margin="0,25,0,0"
            Click="StartButton_Click"/>

    </Grid>
</Window>