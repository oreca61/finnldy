<Window x:Class="Finnldy.UI.GenreSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Genres auswählen"
        Height="500"
        Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Welche Genres möchtest du NICHT sehen?"
                   FontSize="22"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1">
            <StackPanel>

                <CheckBox x:Name="ActionCheckBox" Content="Action" Tag="28" Margin="0,5"/>
                <CheckBox x:Name="AdventureCheckBox" Content="Abenteuer" Tag="12" Margin="0,5"/>
                <CheckBox x:Name="AnimationCheckBox" Content="Animation" Tag="16" Margin="0,5"/>
                <CheckBox x:Name="ComedyCheckBox" Content="Komödie" Tag="35" Margin="0,5"/>
                <CheckBox x:Name="CrimeCheckBox" Content="Krimi" Tag="80" Margin="0,5"/>
                <CheckBox x:Name="DocumentaryCheckBox" Content="Dokumentation" Tag="99" Margin="0,5"/>
                <CheckBox x:Name="DramaCheckBox" Content="Drama" Tag="18" Margin="0,5"/>
                <CheckBox x:Name="FamilyCheckBox" Content="Familie" Tag="10751" Margin="0,5"/>
                <CheckBox x:Name="FantasyCheckBox" Content="Fantasy" Tag="14" Margin="0,5"/>
                <CheckBox x:Name="HorrorCheckBox" Content="Horror" Tag="27" Margin="0,5"/>
                <CheckBox x:Name="RomanceCheckBox" Content="Romanze" Tag="10749" Margin="0,5"/>
                <CheckBox x:Name="SciFiCheckBox" Content="Science Fiction" Tag="878" Margin="0,5"/>
                <CheckBox x:Name="ThrillerCheckBox" Content="Thriller" Tag="53" Margin="0,5"/>
                <CheckBox x:Name="WarCheckBox" Content="Kriegsfilm" Tag="10752" Margin="0,5"/>
                <CheckBox x:Name="WesternCheckBox" Content="Western" Tag="37" Margin="0,5"/>

            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="Start Swipen"
                Height="45"
                Margin="0,20,0,0"
                Click="StartButton_Click"/>

    </Grid>
</Window>