<Window x:Class="Finnldy.UI.WatchLaterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WatchLater Filme"
        Height="650"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#111827"
        Loaded="Window_Loaded">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="WatchLater Filme"
                   Foreground="White"
                   FontSize="40"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,25"/>

        <Border Grid.Row="1"
                Background="#1F2937"
                CornerRadius="24"
                Padding="25">

            <ListBox x:Name="WatchLaterListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="White"
                     FontSize="18"/>
        </Border>

        <Button Grid.Row="2"
                Content="Schließen"
                Width="180"
                Height="45"
                Margin="0,25,0,0"
                HorizontalAlignment="Center"
                Background="#374151"
                Foreground="White"
                FontSize="16"
                FontWeight="Bold"
                BorderThickness="0"
                Click="CloseButton_Click"/>

    </Grid>
</Window>