<Window x:Class="Finnldy.UI.ResultView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finnldy Ergebnis"
        Height="720"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#111827">

    <Grid Margin="30">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Euer Ergebnis"
                   Foreground="White"
                   FontSize="42"
                   FontWeight="Black"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,25"/>

        <Border Grid.Row="1"
                Background="#1F2937"
                CornerRadius="24"
                Padding="25"
                Margin="0,0,0,25">

            <StackPanel>
                <TextBlock Text="Gewinnerfilm"
                           Foreground="#22C55E"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <TextBlock x:Name="WinnerTitleText"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           TextWrapping="Wrap"/>

                <TextBlock x:Name="WinnerInfoText"
                           Foreground="#D1D5DB"
                           FontSize="16"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#1F2937"
                CornerRadius="24"
                Padding="25">

            <StackPanel>
                <TextBlock Text="Weitere gute Filme"
                           Foreground="#F59E0B"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <ListBox x:Name="ResultListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         FontSize="17"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>