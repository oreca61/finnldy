<Window x:Class="Finnldy.UI.ResultView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finnldy Ergebnis"
        Height="820"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#111827">

    <Window.Resources>

        <Style x:Key="HomeButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#E11D48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width" Value="190"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="MinWidth" Value="130"/>
        </Style>

    </Window.Resources>

    <Grid Margin="35">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0"/>
                <GradientStop Color="#1F2937" Offset="0.45"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Home Button oben rechts -->
        <Button Content="Zurück zum Home"
                Style="{StaticResource HomeButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="HomeButton_Click"/>

        <!-- Header -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,24">

            <TextBlock Text="Euer Film-Ergebnis"
                       Foreground="White"
                       FontSize="42"
                       FontWeight="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Basierend auf euren Swipes wurde dieser Film ausgewählt."
                       Foreground="#9CA3AF"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Gewinnerfilm -->
        <Border Grid.Row="1"
                Background="#1F2937"
                CornerRadius="28"
                Padding="26"
                Margin="0,0,0,24"
                BorderBrush="#374151"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="26"
                                  ShadowDepth="0"
                                  Opacity="0.35"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sieger Cover -->
                <Border Grid.Column="0"
                        Width="210"
                        Height="300"
                        Background="#111827"
                        CornerRadius="22"
                        ClipToBounds="True"
                        BorderBrush="#374151"
                        BorderThickness="1">

                    <Image x:Name="WinnerCoverImage"
                           Stretch="UniformToFill"/>
                </Border>

                <!-- Sieger Infos -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">

                    <TextBlock Text="🏆 Gewinnerfilm"
                               Foreground="#22C55E"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <TextBlock x:Name="WinnerTitleText"
                               Foreground="White"
                               FontSize="38"
                               FontWeight="Black"
                               TextWrapping="Wrap"
                               Margin="0,0,0,22"/>

                    <WrapPanel HorizontalAlignment="Left">

                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Score"
                                           Foreground="#9CA3AF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WinnerScoreText"
                                           Foreground="#22C55E"
                                           FontSize="28"
                                           FontWeight="Black"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Likes"
                                           Foreground="#9CA3AF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WinnerLikesText"
                                           Foreground="White"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Dislikes"
                                           Foreground="#9CA3AF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WinnerDislikesText"
                                           Foreground="White"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Später"
                                           Foreground="#9CA3AF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WinnerWatchLaterText"
                                           Foreground="White"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource StatCard}">
                            <StackPanel>
                                <TextBlock Text="Bewertung"
                                           Foreground="#9CA3AF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="WinnerRatingText"
                                           Foreground="#F59E0B"
                                           FontSize="26"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Honorable Mentions -->
        <Border Grid.Row="2"
                Background="#1F2937"
                CornerRadius="28"
                Padding="26"
                BorderBrush="#374151"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Honorable Mentions"
                           Foreground="#F59E0B"
                           FontSize="25"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <StackPanel x:Name="HonorableMentionsPanel"
                            Grid.Row="1"/>
            </Grid>
        </Border>

    </Grid>
</Window>