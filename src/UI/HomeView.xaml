<Window x:Class="Finnldy.UI.HomeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finnldy Home"
        Height="620"
        Width="900"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        WindowStyle="None"
        Background="#111827">
    <!-- Habe wieder nur das Design mit Ki generieren lassen promt: kannst du mir jetzt Lobby view und swipe view in einem ähnlichen design machen wie genreselectionwindow-->

    <Window.Resources>

        <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#E11D48"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Height" Value="58"/>
        <Setter Property="MinWidth" Value="300"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,8"/>
        <Setter Property="Padding" Value="20,0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="18">
                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="#374151"/>
    </Style>

    <Style x:Key="CloseButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="#374151"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Width" Value="42"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                        <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    </Window.Resources>

    <Grid Margin="25">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0"/>
                <GradientStop Color="#1F2937" Offset="0.45"/>
                <GradientStop Color="#0F172A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Button Content="✕"
                Style="{StaticResource CloseButton}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Click="CloseButton_Click"/>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <TextBlock Text="FINNLDY"
                       Foreground="White"
                       FontSize="58"
                       FontWeight="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Finde gemeinsam mit Freunden den perfekten Film."
                       Foreground="#9CA3AF"
                       FontSize="18"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Width="620"
                       Margin="0,8,0,35"/>

            <Border Width="560"
                    Background="#1F2937"
                    CornerRadius="28"
                    Padding="35"
                    BorderBrush="#374151"
                    BorderThickness="1">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="28"
                                      ShadowDepth="0"
                                      Opacity="0.4"/>
                </Border.Effect>

                <StackPanel HorizontalAlignment="Center">

                    <TextBlock Text="Dein Name"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>

                    <TextBox x:Name="UsernameTextBox"
                             Width="360"
                             Height="48"
                             FontSize="18"
                             Padding="12,0"
                             VerticalContentAlignment="Center"
                             Background="#111827"
                             Foreground="White"
                             BorderBrush="#374151"
                             BorderThickness="1"
                             Margin="0,0,0,24"/>

                    <Button Content="Host a Lobby"
                            Style="{StaticResource PrimaryButton}"
                            Click="CreateLobbyButton_Click"/>

                    <Button Content="Join a Lobby"
                            Style="{StaticResource SecondaryButton}"
                            Click="JoinLobbyButton_Click"/>
                    <Button Content="WatchLater Filme anzeigen"
            Style="{StaticResource SecondaryButton}"
            Click="WatchLaterButton_Click"/>    


                </StackPanel>

            </Border>

        </StackPanel>

    </Grid>
</Window>